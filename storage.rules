rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: User is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: User owns the folder
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // SECURITY FIX #4 (continued): Admin uses Custom Claim, not email string.
    // SECURITY FIX #6: Use .get() with a default fallback to prevent a NullPointerException
    // crash when request.auth.token.email is null (e.g. anonymous auth, unverified accounts).
    // The old code `request.auth.token.email.toLowerCase()` would throw if email was null,
    // which could cause Storage rules to behave unpredictably or block all requests.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token != null &&
             'admin' in request.auth.token &&
             request.auth.token.admin == true;
    }

    // --- Profile Pictures ---
    match /profile_pics/{userId}/{allPaths=**} {
      allow read: if true; 
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Bike Garage Photos ---
    match /bikes/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Community Feed Posts ---
    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Shared Trip Snapshots ---
    match /trips/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Ad Banner Uploads (Admin Only) ---
    match /ads/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
  }
}
