rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // SECURITY FIX #4: Admin is determined by a Firebase Custom Claim, NOT by email address.
    //
    // Why: An email string can change, leaks your PII into a public repo, and can be
    // spoofed client-side. Custom Claims are set server-side via the Admin SDK and are
    // cryptographically tied to the user's auth token — they cannot be faked by a client.
    //
    // To grant admin: run this once from a trusted server/script:
    //   await admin.auth().setCustomUserClaims(uid, { admin: true });
    //
    // To revoke admin:
    //   await admin.auth().setCustomUserClaims(uid, { admin: false });
    function isSignedIn() { 
      return request.auth != null && request.auth.uid != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    match /global_bikes/{bikeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // SECURITY FIX: Users can't make themselves admin. 
      // Only an existing admin can set isAdmin to true, or it must be set via Firebase Console.
      allow get: if isSignedIn();
      allow list: if isAdmin() && request.query.limit <= 100;
      allow create: if isSignedIn() && (!request.resource.data.keys().hasAny(['isAdmin']) || request.resource.data.isAdmin == false);
      allow update: if (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']))) || isAdmin();
      allow delete: if isAdmin();
      
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn(); 
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.reviewerId == request.auth.uid || isAdmin());
      }
    }

    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /communities/{communityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isAdmin());

      match /threads/{threadId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());

        match /upvotes/{userId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn() && request.auth.uid == userId;
        }

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
        }
      }
    }

    match /rider_reviews/{reviewId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.reviewerId == request.auth.uid || isAdmin());
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    match /group_rides/{rideId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isAdmin());
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == participantId || isAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == participantId || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/group_rides/$(rideId)).data.creatorId);
      }

      match /requests/{requestId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && (request.auth.uid == requestId || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/group_rides/$(rideId)).data.creatorId);
      }
    }

    match /system/status {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketing_emails/{docId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /referral_codes/{codeId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentUses', 'usedBy']) &&
        request.resource.data.currentUses == resource.data.currentUses + 1 &&
        request.resource.data.currentUses <= resource.data.maxUses
      );
    }
    
    match /bike_submissions/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // B2B / Rental Shop Rules
    match /organizations/{orgId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid));
      
      match /bikes/{bikeId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid);
      }

      match /live_units/{unitId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == unitId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
      }

      match /rentals/{rentalId} {
        allow get, list: if isSignedIn() && (request.auth.uid == resource.data.customerId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid);
      }

      match /rental_requests/{requestId} {
        allow get, list: if isSignedIn() && (request.auth.uid == resource.data.riderId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.riderId;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.riderId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
      }
    }

    match /{path=**}/rental_requests/{requestId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.riderId;
    }
  }
}
