rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email.toLowerCase() == 'mattyfliptv@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow write: if isOwner(userId) || isAdmin();
      
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isAdmin());

      match /threads/{threadId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());

        match /upvotes/{userId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn() && request.auth.uid == userId;
        }

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
        }
      }
    }

    match /rider_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.reviewerId == request.auth.uid || isAdmin());
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    match /group_rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isAdmin());
      
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == participantId || isAdmin());
        allow delete: if isSignedIn() && (request.auth.uid == participantId || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/group_rides/$(rideId)).data.creatorId);
      }

      match /requests/{requestId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && (request.auth.uid == requestId || isAdmin() || request.auth.uid == get(/databases/$(database)/documents/group_rides/$(rideId)).data.creatorId);
      }
    }

    match /system/status {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketing_emails/{docId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /bike_submissions/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // B2B / Rental Shop Rules
    match /organizations/{orgId} {
      allow read: if isSignedIn(); // Allow reading shop basic info
      allow write: if isAdmin() || (isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid));
      
      match /bikes/{bikeId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid);
      }

      match /live_units/{unitId} {
        allow read: if isSignedIn();
        // Allow the unit (rider/bike) to update its own position, or the shop owner
        allow write: if isSignedIn() && (request.auth.uid == unitId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
      }

      match /rentals/{rentalId} {
        allow read: if isSignedIn() && (request.auth.uid == resource.data.customerId || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid || isAdmin());
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid);
      }
    }
  }
}
